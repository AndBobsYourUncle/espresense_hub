# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# user-supplied runtime config (keep config.example.yaml checked in)
/config.yaml

# runtime state — accumulated calibration & device pin data, written by
# the server next to config.yaml. Should never be committed.
/calibration.json
/calibration.json.tmp
/devices.json
/devices.json.tmp
/audit.json
/audit.json.tmp

/.claude/settings.local.json
